# =============================================================================
# .env.example — ETL_V1
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# =============================================================================

# ── Supabase: variables públicas (browser + server) ──────────────────────────
# Estas variables son necesarias tanto en Vercel como en desarrollo local.
# En Vercel: configurar como "Environment Variables" en el dashboard.
# El prefijo NEXT_PUBLIC_ es obligatorio para que Next.js las exponga al browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...  # anon/public key de Supabase

# ── Supabase: variables privadas (solo server-side) ───────────────────────────
# Estas se leen en Route Handlers (server-side) y middleware de Next.js.
# En Vercel: configurar como "Environment Variables" (NO usar NEXT_PUBLIC_).
# NUNCA exponer en código cliente ni en variables NEXT_PUBLIC_.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...      # misma que NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # ⚠️ SECRETO: NO compartir, NO NEXT_PUBLIC_

# ── Next.js / Vercel ──────────────────────────────────────────────────────────
# URL del backend API. En Vercel production, las API Routes son /api/v1 (mismo dominio).
# Dejar vacío o /api/v1 para usar las API Routes de Next.js directamente.
# Solo cambiar si apuntas a un backend FastAPI externo.
NEXT_PUBLIC_API_URL=/api/v1

# ── Solo desarrollo local ──────────────────────────────────────────────────────
# Estas variables NO van en Vercel. Son para el entorno local con Docker.
ENVIRONMENT=development
APP_NAME="ETL Contable API"
APP_VERSION=1.0.0
DEBUG=false
API_PORT=8000
WEB_PORT=3000

# ── Python / FastAPI (solo local) ─────────────────────────────────────────────
# Usadas por el backend FastAPI (apps/api). No aplican a Vercel.
# JWT_SECRET debe cambiarse en cualquier entorno real.
JWT_SECRET=change-this-super-secret-key-in-production-min-32-chars
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://etl-v1.vercel.app"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_SIZE_MB=50

# ── Worker / Docker (solo local) ──────────────────────────────────────────────
# Usadas por el Celery worker y docker-compose. No aplican a Vercel.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=etl_db
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=etl_pass
DATABASE_URL=postgresql+psycopg://etl_user:etl_pass@localhost:5432/etl_db
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
# DATA_DIR=/ruta/absoluta/a/ETL_V1/data

