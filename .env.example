# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME="ETL Contable API"
APP_VERSION=1.0.0
DEBUG=false
API_PORT=8000
WEB_PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=etl_db
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=etl_pass
DATABASE_URL=postgresql+psycopg://etl_user:etl_pass@localhost:5432/etl_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANTE: Cambia estos valores en producción
JWT_SECRET=change-this-super-secret-key-in-production-min-32-chars
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

