# =============================================================================
# apps/web/.env.example — Variables para Next.js (Vercel + desarrollo local)
# Copia a .env.local para desarrollo local.
# En Vercel: configurar en Dashboard → Settings → Environment Variables.
# =============================================================================

# ── Supabase: variables públicas (browser + server) ──────────────────────────
# Obligatorias en Vercel y en desarrollo local.
# Next.js necesita el prefijo NEXT_PUBLIC_ para exponer variables al browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...  # anon/public key de Supabase

# ── Supabase: variables privadas (server-side únicamente) ─────────────────────
# Obligatorias en Vercel. NO usar prefijo NEXT_PUBLIC_ para estas.
# utils/supabase/env.ts las prefiere sobre NEXT_PUBLIC_ en server-side.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...  # misma que NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY

# ── Supabase: service role key (server-side, SECRETO) ─────────────────────────
# Usada en API Routes para operaciones admin (getSupabaseAdminClient).
# NUNCA poner con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # ⚠️ Secreto — NO compartir

# ── API URL ───────────────────────────────────────────────────────────────────
# En Vercel (producción): las API Routes de Next.js están en /api/v1.
# En desarrollo local apuntando a FastAPI: http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=/api/v1
